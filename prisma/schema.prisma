// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  MARKETING
  COMMERCIAL
  DIRECTION
  ADMIN
  ACHAT
}

enum LeadStatut {
  NOUVEAU
  EN_COURS
  DEVIS
  VENTE
  PERDU
}

enum LeadSource {
  META_ADS
  GOOGLE_ADS
  SITE_WEB
  GLIDE
  SALON
  FORMULAIRE
  DIRECT
}

enum LeadPriorite {
  HAUTE
  NORMALE
  BASSE
}

enum LifecycleStage {
  PROSPECT
  LEAD
  CLIENT
  INACTIF
}

enum Plateforme {
  META
  GOOGLE
  EMAIL
  SMS
  SALON
  AUTRE
}

enum DevisStatut {
  EN_ATTENTE
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

enum EvenementType {
  CREATION_LEAD
  EMAIL_ENVOYE
  SMS_ENVOYE
  APPEL
  NOTE
  DEVIS_CREE
  VENTE
  RELANCE
  CHANGEMENT_STATUT
  VISITE_WEB
}

enum TaskStatut {
  A_FAIRE
  EN_COURS
  TERMINEE
}

enum WorkflowTrigger {
  // Legacy
  NOUVEAU_LEAD
  LEAD_INACTIF
  DEVIS_NON_FACTURE
  POST_ACHAT
  SLA_DEPASSE
  // New automatisations triggers
  NOUVELLE_DEMANDE
  CONTACT_CREE
  DEVIS_ENVOYE
  DEVIS_SANS_REPONSE_3J
  DEVIS_SANS_REPONSE_7J
  VENTE_CONFIRMEE
  LEAD_STATUT_CHANGE
  MANUEL
}

enum EmailStatut {
  ENVOYE
  OUVERT
  CLIQUE
  BOUNCE
  ERREUR
}

enum CampagneEmailStatut {
  BROUILLON
  PLANIFIE
  EN_COURS
  TERMINE
}

enum CoutType {
  SALON
  AGENCE
  PRINT
  AUTRE
}

// ============================================================================
// MODELS
// ============================================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  nom             String
  prenom          String
  passwordHash    String
  totpSecret      String?
  role            Role
  titre           String?
  telephone       String?
  showroomId      String?
  actif           Boolean   @default(true)
  couleur         String?   // couleur hex pour calendrier congés (#FF6B6B)
  pointageActif   Boolean   @default(true) // false = pas de pointage (Liliane, Alain)
  pointageDelegueId String? // userId de la personne qui peut pointer pour ce user
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  showroom        Showroom? @relation(fields: [showroomId], references: [id], onDelete: SetNull)
  leadsAssignes   Lead[]    @relation("LeadCommercial")
  evenements      Evenement[] @relation("EvenementAuteur")
  auditLogs       AuditLog[] @relation("AuditLogUser")
  postPlannings   PostPlanning[] @relation("PostPlanningAuteur")
  liaisons        LiaisonDevisCommande[]
  brevoSyncLogs   BrevoSyncLog[]
  tasksAssignees  Task[]         @relation("TaskAssignee")
  tasksCreees     Task[]         @relation("TaskCreator")
  clientsBdoVerifies ClientBoisDOrient[] @relation("ClientBdoVerifie")
  conges               Conge[]        @relation("CongeUser")
  congesApprouves      Conge[]        @relation("CongeApprobateur")
  pointages            Pointage[]     @relation("PointageUser")
  pointagesCorrections Pointage[]     @relation("PointageCorrecteur")
  savAssignes          DossierSAV[]   @relation("SAVAssigne")
  savCrees             DossierSAV[]   @relation("SAVCreateur")
  documentsSav         DocumentSAV[]
  commentairesSav      CommentaireSAV[]

  @@index([showroomId])
}

model Showroom {
  id              String    @id @default(cuid())
  nom             String
  adresse         String?
  emailNotif      String?
  createdAt       DateTime  @default(now())

  // Relations
  users           User[]
  contacts        Contact[]
  leads           Lead[]

  @@index([nom])
}

model Contact {
  id                  String    @id @default(cuid())
  email               String    @unique
  telephone           String?
  nom                 String
  prenom              String
  adresse             String?
  ville               String?
  codePostal          String?
  showroomId          String?
  sourcePremiere      String?
  lifecycleStage      LifecycleStage @default(PROSPECT)
  rgpdEmailConsent    Boolean   @default(false)
  rgpdSmsConsent      Boolean   @default(false)
  rgpdConsentDate     DateTime?
  rgpdConsentSource   String?
  // Consentements Glideapps
  consentOffre        Boolean   @default(false)
  consentNewsletter   Boolean   @default(false)
  consentInvitation   Boolean   @default(false)
  consentDevis        Boolean   @default(false)
  // Glideapps sync
  glideRowId          String?   @unique
  sellsyContactId     String?   @unique
  scoreRfm            Int?
  recence             Int?
  frequence           Int?
  montant             Float?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  showroom            Showroom? @relation(fields: [showroomId], references: [id], onDelete: SetNull)
  leads               Lead[]
  devis               Devis[]
  ventes              Vente[]
  evenements          Evenement[]
  clickEvents         ClickEvent[]
  emailLogs           EmailLog[]
  smsLogs             SmsLog[]
  // workflowLogs removed — replaced by WorkflowExecution
  demandesPrix        DemandePrix[]
  tasks               Task[]
  dossiersSav         DossierSAV[]

  @@index([telephone])
  @@index([sellsyContactId])
  @@index([glideRowId])
  @@index([showroomId])
}

model Lead {
  id                  String    @id @default(cuid())
  contactId           String
  showroomId          String?
  commercialId        String?
  statut              LeadStatut @default(NOUVEAU)
  source              LeadSource
  campagneId          String?
  produitsDemandes    Json?
  utmSource           String?
  utmMedium           String?
  utmCampaign         String?
  utmContent          String?
  utmTerm             String?
  gclid               String?
  metaClickId         String?
  attributionDate     DateTime?
  slaDeadline         DateTime
  premiereActionAt    DateTime?
  priorite            LeadPriorite @default(NORMALE)
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  contact             Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  showroom            Showroom? @relation(fields: [showroomId], references: [id], onDelete: SetNull)
  commercial          User?     @relation("LeadCommercial", fields: [commercialId], references: [id], onDelete: SetNull)
  campagne            Campagne? @relation(fields: [campagneId], references: [id], onDelete: SetNull)
  devis               Devis[]
  evenements          Evenement[]
  // workflowLogs removed — replaced by WorkflowExecution

  @@index([contactId])
  @@index([commercialId])
  @@index([statut])
  @@index([campagneId])
  @@index([createdAt])
}

model Campagne {
  id                  String    @id @default(cuid())
  nom                 String
  plateforme          Plateforme
  coutTotal           Float     @default(0)
  dateDebut           DateTime?
  dateFin             DateTime?
  metaCampaignId      String?
  metaAdsetId         String?
  metaAdId            String?
  googleCampaignId    String?
  actif               Boolean   @default(true)
  metaInsights        Json?     // Cache des métriques Meta (impressions, clicks, ctr, cpc, roas, conversions)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  leads               Lead[]
  coutsOffline        CoutOffline[]

  @@index([nom])
  @@index([plateforme])
}

model Devis {
  id                  String    @id @default(cuid())
  leadId              String?
  contactId           String
  sellsyQuoteId       String?   @unique
  numero              String?   // Ex: "DEPI-08028" — numéro lisible Sellsy
  montant             Float
  statut              DevisStatut @default(EN_ATTENTE)
  dateEnvoi           DateTime?
  dateRelance         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  lead                Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact             Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  vente               Vente?

  @@index([leadId])
  @@index([contactId])
  @@index([statut])
}

model Vente {
  id                  String    @id @default(cuid())
  devisId             String?   @unique
  contactId           String
  sellsyInvoiceId     String?   @unique
  montant             Float
  dateVente           DateTime
  produits            Json?
  createdAt           DateTime  @default(now())

  // Relations
  devis               Devis?    @relation(fields: [devisId], references: [id], onDelete: SetNull)
  contact             Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([dateVente])
}

model Evenement {
  id                  String    @id @default(cuid())
  contactId           String?
  leadId              String?
  type                EvenementType
  description         String
  metadata            Json?
  auteurId            String?
  createdAt           DateTime  @default(now())

  // Relations
  contact             Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead                Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  auteur              User?     @relation("EvenementAuteur", fields: [auteurId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([leadId])
  @@index([createdAt])
}

model ClickEvent {
  id                  String    @id @default(cuid())
  contactId           String?
  utmSource           String?
  utmMedium           String?
  utmCampaign         String?
  utmContent          String?
  utmTerm             String?
  gclid               String?
  metaClickId         String?
  pageUrl             String?
  referrer            String?
  ipHash              String?
  createdAt           DateTime  @default(now())

  // Relations
  contact             Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([createdAt])
}

// Old Workflow/WorkflowAction/WorkflowLog models replaced by new ones at end of file

model EmailCampaign {
  id                  String    @id @default(cuid())
  nom                 String
  objet               String
  contenuHtml         String
  segmentFilter       Json?
  statut              CampagneEmailStatut @default(BROUILLON)
  dateEnvoiPlanifie   DateTime?
  nbEnvoyes           Int       @default(0)
  nbOuverts           Int       @default(0)
  nbClics             Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  emailLogs           EmailLog[] @relation("EmailCampaignLog")

  @@index([statut])
}

model EmailLog {
  id                  String    @id @default(cuid())
  contactId           String
  campaignId          String?
  objet               String
  statut              EmailStatut
  resendId            String?
  sentAt              DateTime
  createdAt           DateTime  @default(now())

  // Relations
  contact             Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign            EmailCampaign? @relation("EmailCampaignLog", fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([campaignId])
  @@index([sentAt])
}

model SmsLog {
  id                  String    @id @default(cuid())
  contactId           String
  message             String
  statut              String
  twilioSid           String?
  sentAt              DateTime
  createdAt           DateTime  @default(now())

  // Relations
  contact             Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([sentAt])
}

model AuditLog {
  id                  String    @id @default(cuid())
  userId              String?
  action              String
  entite              String
  entiteId            String?
  details             Json?
  ipAddress           String?
  createdAt           DateTime  @default(now())

  // Relations
  user                User?     @relation("AuditLogUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model CoutOffline {
  id                  String    @id @default(cuid())
  campagneId          String
  description         String
  montant             Float
  type                CoutType
  date                DateTime
  createdAt           DateTime  @default(now())

  // Relations
  campagne            Campagne  @relation(fields: [campagneId], references: [id], onDelete: Cascade)

  @@index([campagneId])
  @@index([date])
}

model DemandePrix {
  id                  String    @id @default(cuid())
  contactId           String
  meuble              String
  message             String?
  glideRowId          String?   @unique
  showroom            String?
  modePaiement        String?
  budget              String?
  articles            Json?     // [{nom, categorie, finition, quantite}]
  estimationHT        Float?
  estimationTTC       Float?
  estimationDetails   Json?     // Résultat du matching IA Sellsy
  dateDemande         DateTime?
  createdAt           DateTime  @default(now())

  // Relations
  contact             Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([dateDemande])
}

// ============================================================================
// AUTOMATISATIONS — Workflows & Email Templates
// ============================================================================

model Workflow {
  id                  String            @id @default(cuid())
  nom                 String
  description         String?
  trigger             WorkflowTrigger
  enabled             Boolean           @default(true)
  delaiMinutes        Int               @default(0)     // Délai avant exécution (ex: 3j = 4320)
  conditions          Json?             // Conditions supplémentaires (JSON)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Relations
  emailTemplate       EmailTemplate?
  executions          WorkflowExecution[]

  @@index([trigger])
  @@index([enabled])
}

model EmailTemplate {
  id                  String    @id @default(cuid())
  workflowId          String    @unique
  nom                 String
  sujet               String    // Subject avec variables {{prenom}}, {{nom}}, etc.
  contenuHtml         String    // Body HTML avec variables
  contenuTexte        String?   // Version texte brut
  variables           Json?     // Liste des variables disponibles
  brevoTemplateId     Int?      // ID du template Brevo si synchronisé
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  workflow            Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model WorkflowExecution {
  id                  String    @id @default(cuid())
  workflowId          String
  contactId           String?
  statut              String    @default("SUCCESS") // SUCCESS, ERROR, SKIPPED
  details             Json?     // Détails de l'exécution (email envoyé, erreur, etc.)
  createdAt           DateTime  @default(now())

  // Relations
  workflow            Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([createdAt])
}

// ============================================================================
// PLANNING POSTS — Kanban Board
// ============================================================================

enum PostStatut {
  IDEE
  PRE_PRODUCTION
  VISUEL_OK
  TEXTE_OK
  PRET_A_POSTER
  POSTE
  INSPIRATIONS
  COUVERTURES_FB
}

enum PostLabel {
  PILIER_1_MATIERE
  PARCOURS_DECOUVERTE
  CONTEXTE_EVENEMENT
  PILIER_2_COMPRENDRE
  PARCOURS_PEDAGOGIE
  CONTEXTE_NEWSLETTER
  PARCOURS_PROJECTION
  CANAL_META
  PILIER_3_MAGASIN
  CANAL_GOOGLE
  PARCOURS_ACTION
  CONTEXTE_PUBLICITE
  PARCOURS_FIDELISATION
  CANAL_STORY
  AVIS_CLIENTS
  FIDELISATION
  TEASING_AVRIL
  VIDEO_REEL
  BLOG_SEO
  EMAIL_BREVO
  STORY
}

model PostPlanning {
  id          String      @id @default(cuid())
  title       String
  description String?
  statut      PostStatut  @default(IDEE)
  position    Int         @default(0)
  dueDate       DateTime?
  scheduledDate DateTime?
  labels        PostLabel[] @default([])
  coverImage    String?
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  createdBy   User        @relation("PostPlanningAuteur", fields: [createdById], references: [id], onDelete: SetNull)
  checklist   PostChecklist[]
  attachments PostAttachment[]

  @@index([statut])
  @@index([createdById])
  @@index([dueDate])
  @@index([scheduledDate])
}

model PostChecklist {
  id        String   @id @default(cuid())
  postId    String
  text      String
  checked   Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  // Relations
  post      PostPlanning @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostAttachment {
  id        String   @id @default(cuid())
  postId    String
  fileName  String
  fileUrl   String
  fileType  String   @default("application/octet-stream")
  createdAt DateTime @default(now())

  // Relations
  post      PostPlanning @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ============================================================================
// OBJECTIFS COMMERCIAUX
// ============================================================================

model ObjectifCommercial {
  id        String   @id @default(cuid())
  month     Int      // 1-12
  year      Int
  amount    Float    // Objectif CA mensuel en EUR (HT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year])
}

// ============================================================================
// LIENS UTILES (Marketing)
// ============================================================================

model LienUtile {
  id          String   @id @default(cuid())
  nom         String
  url         String
  description String?
  categorie   String   // ex: "CRM", "Réseaux", "CMS", "Outils internes"
  iconeUrl    String?  // URL favicon ou icône custom
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categorie])
}

// ============================================================================
// TRAÇABILITÉ DEVIS → COMMANDES (liaison manuelle Sellsy)
// ============================================================================

model LiaisonDevisCommande {
  id          String   @id @default(cuid())
  estimateId  Int      // ID Sellsy du devis
  orderId     Int      // ID Sellsy de la commande
  createdById String
  createdAt   DateTime @default(now())

  createdBy   User     @relation(fields: [createdById], references: [id])

  @@unique([estimateId, orderId])
  @@index([estimateId])
  @@index([orderId])
}

// ============================================================================
// CHAÎNE DOCUMENTAIRE SELLSY V1 (Devis → BC → BL → Facture)
// ============================================================================

model LiaisonDocumentaire {
  id              String   @id @default(cuid())
  enfantType      String   // "order" | "invoice" | "delivery"
  enfantSellsyId  String
  enfantNumero    String
  parentType      String   // "estimate" | "order" | "delivery"
  parentSellsyId  String
  parentNumero    String
  confirmeManuel  Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([enfantType, enfantSellsyId])
  @@index([parentSellsyId])
}

// ============================================================================
// SYNC BREVO (historique des synchronisations Sellsy → Brevo)
// ============================================================================

model BrevoSyncLog {
  id           String   @id @default(cuid())
  segmentNom   String
  nbContacts   Int
  statut       String   // "success" | "error"
  erreur       String?
  createdAt    DateTime @default(now())
  createdById  String

  createdBy    User     @relation(fields: [createdById], references: [id])

  @@index([createdAt])
}

// ============================================================================
// BREVO WEBHOOK EVENTS
// ============================================================================

model BrevoWebhookEvent {
  id        String   @id @default(cuid())
  event     String   // delivered, opened, clicked, soft_bounce, hard_bounce, unsubscribed, spam
  email     String
  messageId String?
  subject   String?
  tag       String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([event])
  @@index([createdAt])
}

// ============================================================================
// DOCUMENTATION (articles d'aide internes)
// ============================================================================

model DocArticle {
  id        String   @id @default(cuid())
  titre     String
  slug      String   @unique
  contenu   String   // Markdown
  categorie String
  position  Int      @default(0)
  publie    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categorie])
  @@index([slug])
}

// ============================================================================
// TÂCHES COMMERCIALES
// ============================================================================

model Task {
  id          String     @id @default(cuid())
  titre       String
  description String?
  echeance    DateTime?
  statut      TaskStatut @default(A_FAIRE)
  contactId   String?
  assigneAId  String
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  contact     Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assigneA    User       @relation("TaskAssignee", fields: [assigneAId], references: [id])
  createdBy   User       @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([assigneAId])
  @@index([echeance])
  @@index([statut])
}

// ============================================================================
// CLUB TECTONA — Programme de fidélité
// ============================================================================

model ClubMembre {
  id              String   @id @default(cuid())
  sellsyContactId String   @unique
  email           String
  nom             String
  prenom          String
  niveau          Int      @default(1)   // 1-5
  totalCommandes  Int      @default(0)
  totalMontant    Float    @default(0)
  origine         String   @default("DIMEXOI") // "DIMEXOI" | "BDO" | "LES_DEUX"
  dateEntree      DateTime @default(now())
  dernierSync     DateTime?
  brevoSynced     Boolean  @default(false)
  sellsySynced    Boolean  @default(false)
  exclu           Boolean  @default(false)  // soft-delete : retiré du programme
  codePromo       String?                  // code promo unique (ex: CLUB-III-A7K9)
  bonUtilise      Boolean  @default(false) // le client a utilisé son bon de remise
  dateBonUtilise  DateTime?                // date d'utilisation du bon
  niveauEmailEnvoye Int?                   // dernier niveau pour lequel un email a été envoyé
  dernierEmailDate  DateTime?              // date du dernier email envoyé
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([niveau])
  @@index([email])
}

// ============================================================================
// BOIS D'ORIENT — Migration données enseigne fermée
// ============================================================================

model ClientBoisDOrient {
  id                String    @id @default(cuid())
  sellsyIdBdo       String?   @unique  // ID dans Sellsy Bois d'Orient
  nom               String
  prenom            String?
  email             String?
  telephone         String?
  adresse           String?
  ville             String?
  nbCommandes       Int       @default(0)
  nbFactures        Int       @default(0)
  nbDevis           Int       @default(0)
  totalCA           Float     @default(0)  // CA TTC total des FACTURES (pour fidélité)
  premiereFacture   DateTime?
  derniereFacture   DateTime?
  commandesDetail   Json?     // [{date, montant, ref, type}]
  statut            String    @default("NOUVEAU") // NOUVEAU | MATCH_EMAIL | MATCH_MANUEL | A_VERIFIER
  contactDimexoiId  String?   // sellsyContactId DIMEXOI si matché
  verifieLeAt       DateTime?
  verifieParId      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  verifiePar        User?     @relation("ClientBdoVerifie", fields: [verifieParId], references: [id], onDelete: SetNull)
  documents         DocumentBoisDOrient[]

  @@index([email])
  @@index([statut])
}

model DocumentBoisDOrient {
  id              String   @id @default(cuid())
  sellsyDocId     String   @unique  // ID document Sellsy BDO
  clientBdoId     String
  type            String   // "FACTURE" | "COMMANDE" | "DEVIS"
  reference       String?  // numéro du document
  date            DateTime
  montantTTC      Float    @default(0)
  montantHT       Float    @default(0)
  statut          String?  // statut Sellsy (payée, envoyée, etc.)
  pdfUrl          String?  // URL publique Supabase Storage
  pdfPath         String?  // path dans le bucket Supabase
  createdAt       DateTime @default(now())

  // Relations
  clientBdo       ClientBoisDOrient @relation(fields: [clientBdoId], references: [id], onDelete: Cascade)

  @@index([clientBdoId])
  @@index([type])
}

model ImportBoisDOrient {
  id              String   @id @default(cuid())
  dateImport      DateTime @default(now())
  nbContactsTotal Int      @default(0)
  nbMatchEmail    Int      @default(0)
  nbAVerifier     Int      @default(0)
  nbNouveaux      Int      @default(0)
  nbDocuments     Int      @default(0)
  statut          String   @default("EN_COURS") // EN_COURS | TERMINE | ERREUR
  notes           String?
}

// ============================================================================
// CONGÉS & ABSENCES
// ============================================================================

model Conge {
  id            String    @id @default(cuid())
  userId        String
  type          String    @default("conge_paye") // conge_paye | rtt | sans_solde | maladie
  dateDebut     DateTime
  dateFin       DateTime
  nbJours       Float     @default(1)
  statut        String    @default("en_attente") // en_attente | approuve | modifie | refuse
  notes         String?
  commentaire   String?   // commentaire du responsable
  approuveParId String?
  approuveLe    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation("CongeUser", fields: [userId], references: [id], onDelete: Cascade)
  approuvePar   User?     @relation("CongeApprobateur", fields: [approuveParId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([dateDebut])
  @@index([statut])
}

// ============================================================================
// POINTAGE (Time tracking)
// ============================================================================

model Pointage {
  id                String    @id @default(cuid())
  userId            String
  date              DateTime  @db.Date
  arrivee           DateTime?
  debutPause        DateTime?
  finPause          DateTime?
  depart            DateTime?
  heuresTravaillees Float?
  heuresSupp        Float?
  corrigeParId      String?
  noteCorrection    String?
  corrigeLe         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation("PointageUser", fields: [userId], references: [id], onDelete: Cascade)
  corrigePar        User?     @relation("PointageCorrecteur", fields: [corrigeParId], references: [id], onDelete: SetNull)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model ConfigPointage {
  id                    String   @id @default(cuid())
  heuresTheoriquesJour  Float    @default(7)
  heurePauseDefaut      Float    @default(1)
  updatedAt             DateTime @updatedAt
}

model ConfigApp {
  id                    String   @id @default("default")
  slaHeures             Int      @default(72)
  pointageHeuresJour    Float    @default(7)
  pointagePauseDefaut   Float    @default(1)
  updatedAt             DateTime @updatedAt
}

// ============================================================================
// SAV / LITIGES
// ============================================================================

model DossierSAV {
  id              String           @id @default(cuid())
  numero          String           @unique
  titre           String
  type            String
  statut          String           @default("A_TRAITER")
  sellsyBdcId     String?
  sellsyBdcRef    String?
  sellsyContactId String?
  contactNom      String?
  contactId       String?
  assigneId       String?
  creePar         String
  description     String?
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  contact         Contact?         @relation(fields: [contactId], references: [id])
  assigne         User?            @relation("SAVAssigne", fields: [assigneId], references: [id])
  creeParUser     User             @relation("SAVCreateur", fields: [creePar], references: [id])
  documents       DocumentSAV[]
  commentaires    CommentaireSAV[]

  @@index([statut])
  @@index([contactId])
  @@index([createdAt])
}

model DocumentSAV {
  id        String     @id @default(cuid())
  dossierId String
  nom       String
  type      String
  url       String?
  contenu   String?
  taille    Int?
  ajoutePar String
  createdAt DateTime   @default(now())

  dossier   DossierSAV @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  ajoute    User       @relation(fields: [ajoutePar], references: [id])
}

model CommentaireSAV {
  id        String     @id @default(cuid())
  dossierId String
  contenu   String
  auteurId  String
  createdAt DateTime   @default(now())

  dossier   DossierSAV @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  auteur    User       @relation(fields: [auteurId], references: [id])
}
